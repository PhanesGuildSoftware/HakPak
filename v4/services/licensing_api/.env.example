# Required for admin endpoints
HAKPAK_ADMIN_TOKEN=replace-with-long-random-token

# Optional: protect public validate endpoint from abuse
HAKPAK_CLIENT_AUTH_TOKEN=replace-with-long-random-token

# Optional: if omitted, data is stored in ./data/licensing.db
HAKPAK_LICENSE_DATA_DIR=./data

# ── Email delivery (Resend) ───────────────────────────────────────────────────
# All three fields are required to enable license key delivery emails.
# Leave RESEND_API_KEY blank to skip email (keys are still stored and
# retrievable via admin API).
RESEND_API_KEY=replace-with-resend-api-key
# Sender address (must be verified in Resend dashboard)
SMTP_FROM=noreply@phanesguild.com
SMTP_FROM_NAME=HakPak4 Licensing

# ── Shopify webhook signing secret ────────────────────────────────────────────
# Copy from: Shopify Admin → Settings → Notifications → Webhooks (top of page)
SHOPIFY_WEBHOOK_SECRET=replace-with-your-shopify-webhook-secret

# JSON map of Shopify SKU -> HakPak4 tier
# Set this to match the SKU on your Shopify product variant
SHOPIFY_SKU_TIER_MAP={"HPAK-PRO":"pro"}

# Optional: override default device limit
# HAKPAK_TIER_MAX_DEVICES={"pro":3}
